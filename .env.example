WHISPER_PAYMENT_MODE=magicblock-live
MAGICBLOCK_API_BASE=https://payments.magicblock.app
MAGICBLOCK_CLUSTER=devnet
MAGICBLOCK_EPHEMERAL_RPC_URL=https://devnet.magicblock.app
MAGICBLOCK_VALIDATOR=MTEWGuqxUpYZGFJQcp8tLN7x5v9BSeoFHYWQQ3n3xzo

# Set this to the SPL mint you want to test with on the selected cluster.
# For devnet, use a devnet mint you control or one provided by your sponsor.
MAGICBLOCK_MINT=
MAGICBLOCK_MINT_DECIMALS=6

# Optional base RPC override.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Use one of these formats:
# WHISPER_SIGNER_SECRET=[1,2,3,...]
# WHISPER_SIGNER_SECRET=base64:AAAA...
# WHISPER_SIGNER_SECRET=<base58-secret>
WHISPER_SIGNER_SECRET=

# Provider receives the private transfer here.
# If WHISPER_PROVIDER_SECRET is set, you can leave this blank and it will derive automatically.
WHISPER_PROVIDER_DESTINATION=

# Optional. If set together with WHISPER_PROVIDER_WITHDRAW=true, the app will
# attempt a real provider withdrawal back to Solana base balance.
WHISPER_PROVIDER_SECRET=
WHISPER_PROVIDER_WITHDRAW=false

WHISPER_MEMO_PREFIX=WhisperAPI

# Optional. Protects /api/state, /api/reset, and /api/integration/status on shared deployments.
# Localhost requests are allowed without this token unless you set it explicitly.
WHISPER_ADMIN_TOKEN=

# Optional. Override where in-memory receipt/session state is persisted.
WHISPER_STATE_FILE=

# Optional. Hard cap per payment in human-readable USDC units.
WHISPER_MAX_PAYMENT_USDC=5
